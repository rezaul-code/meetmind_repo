<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginTop="36dp"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/meetmind_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeColor="#14000000"
    app:strokeWidth="1dp"
    app:rippleColor="@color/meetmind_primary_container">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:padding="18dp">

        <!-- Recording Icon -->

        <ImageView
            android:id="@+id/iconView"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_recording_icon"
            android:padding="12dp"
            android:src="@drawable/ic_recording_file"
            android:tint="@color/meetmind_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="UseAppTint"/>

        <!-- Recording Name -->

        <TextView
            android:id="@+id/fileNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/meetmind_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iconView"
            app:layout_constraintTop_toTopOf="@id/iconView"
            app:layout_constraintEnd_toStartOf="@id/chevronView"
            tools:text="Weekly Team Meeting"/>

        <!-- Recording Date -->

        <TextView
            android:id="@+id/dateText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="12dp"
            android:textColor="@color/meetmind_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/iconView"
            app:layout_constraintTop_toBottomOf="@id/fileNameText"
            app:layout_constraintEnd_toStartOf="@id/chevronView"
            tools:text="25 Jun 2026 • 06:00 PM"/>

        <!-- Hidden Duration (Keep for Java compatibility) -->

        <TextView
            android:id="@+id/durationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_duration_badge"
            android:textColor="@color/meetmind_primary"
            android:textStyle="bold"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chevronView"
            tools:text="12:31"/>

        <!-- Chevron -->

        <ImageView
            android:id="@+id/chevronView"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="4dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/meetmind_secondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="UseAppTint"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>