<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/meetmind_background"
    tools:context=".RecordingDetailsActivity">

    <!--
        ROOT FIX: LinearLayout with wrap_content height.
        NO card uses layout_weight or layout_height="0dp".
        Every card is wrap_content — zero empty space.
        Bottom buttons sit naturally below player card.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- ════════════════════════════════ -->
        <!--           HEADER CARD            -->
        <!-- ════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/meetmind_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/headerIcon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_recording_icon"
                    android:padding="10dp"
                    android:src="@drawable/ic_recording_file"
                    android:tint="@color/meetmind_primary"
                    tools:ignore="UseAppTint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/titleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/meetmind_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        tools:text="Meeting_20260616_180000" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="12sp"
                        tools:text="Ready to play" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════════════════════════════ -->
        <!--        RECORDING INFO CARD       -->
        <!-- ════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/detailsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/meetmind_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/recordingNameLabel"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_name_label"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/recordingNameText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/meetmind_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Meeting_20260616_180000" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.15"
                    android:background="@color/meetmind_secondary" />

                <!-- Date · Duration · Size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_date_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/recordingDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="12sp"
                            tools:text="16 Jun 2026" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_duration_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/recordingDurationText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="12sp"
                            tools:text="00:12:31" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_size_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/recordingSizeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="12sp"
                            tools:text="8.4 MB" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.15"
                    android:background="@color/meetmind_secondary" />

                <!-- Path row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_path_label"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/recordingPathText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="middle"
                        android:maxLines="1"
                        android:textColor="@color/meetmind_secondary"
                        android:textIsSelectable="true"
                        android:textSize="10sp"
                        tools:text="/storage/emulated/0/Android/data/com.office.meetmind/files/Music/Meeting_20260616_180000.m4a" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════════════════════════════ -->
        <!--         AUDIO PLAYER CARD        -->
        <!--                                  -->
        <!--  KEY FIX: layout_height is       -->
        <!--  wrap_content — NOT 0dp/weight.  -->
        <!--  No empty space. Content-driven. -->
        <!-- ════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/playerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/meetmind_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Audio Player"
                    android:textColor="@color/meetmind_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- SeekBar -->
                <SeekBar
                    android:id="@+id/playbackSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="1000"
                    android:progress="0" />

                <!-- Time labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/currentTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="11sp"
                        tools:text="00:00:00" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/totalTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="11sp"
                        tools:text="00:12:31" />
                </LinearLayout>

                <!--
                    BUTTON FIX: All outlined buttons have explicit
                    app:strokeColor="@color/meetmind_primary" and
                    app:strokeWidth="1.5dp" so they are always visible,
                    including in the disabled (alpha-reduced) state.
                -->

                <!-- Play + Pause -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/playButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/play_audio"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pauseButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/pause_audio"
                        android:textColor="@color/meetmind_primary"
                        app:icon="@drawable/ic_pause"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/meetmind_primary"
                        app:strokeColor="@color/meetmind_primary"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>

                <!-- Resume + Stop -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resumeButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/resume_audio"
                        android:textColor="@color/meetmind_primary"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/meetmind_primary"
                        app:strokeColor="@color/meetmind_primary"
                        app:strokeWidth="1.5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stopButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/stop_audio"
                        android:textColor="@color/meetmind_primary"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/meetmind_primary"
                        app:strokeColor="@color/meetmind_primary"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════════════════════════════ -->
        <!--     GENERATE TRANSCRIPT BUTTON   -->
        <!-- ════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/transcribeButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:text="@string/generate_transcript" />

        <!-- ════════════════════════════════ -->
        <!--        DELETE RECORDING          -->
        <!-- ════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/delete_recording"
            android:textColor="?attr/colorError"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconTint="?attr/colorError"
            app:strokeColor="?attr/colorError"
            app:strokeWidth="1.5dp" />

    </LinearLayout>

    <!-- Centered loading overlay — lives in FrameLayout so it's truly centered -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone"
        tools:visibility="gone" />

</FrameLayout>