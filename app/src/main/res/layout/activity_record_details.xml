<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/meetmind_background"
    android:fillViewport="true"
    tools:context=".RecordingDetailsActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="48dp">

            <!-- ════════════════════════════════════════ -->
            <!--              HEADER CARD                 -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/meetmind_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="24dp">

                    <ImageView
                        android:id="@+id/headerIcon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_recording_icon"
                        android:padding="14dp"
                        android:src="@drawable/ic_recording_file"
                        android:tint="@color/meetmind_primary"
                        tools:ignore="UseAppTint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/titleText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="Meeting_20260616_180000" />

                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="13sp"
                            tools:text="Player Ready" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!--           RECORDING INFO CARD            -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/detailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/meetmind_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Section header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Recording Info"
                        android:textColor="@color/meetmind_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01" />

                    <!-- ── Name ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/recordingNameLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_name_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/recordingNameText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="Meeting_20260616_180000" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="0dp"
                        android:alpha="0.10"
                        android:background="@color/meetmind_secondary" />

                    <!-- ── Date ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_date_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/recordingDateText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/meetmind_primary"
                            android:textSize="15sp"
                            tools:text="16 Jun 2026, 06:00 PM" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:alpha="0.10"
                        android:background="@color/meetmind_secondary" />

                    <!-- ── Duration + Size side-by-side ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_duration_label"
                                android:textColor="@color/meetmind_secondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/recordingDurationText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/meetmind_primary"
                                android:textSize="15sp"
                                tools:text="00:12:31" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="20dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_size_label"
                                android:textColor="@color/meetmind_secondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/recordingSizeText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/meetmind_primary"
                                android:textSize="15sp"
                                tools:text="8.4 MB" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:alpha="0.10"
                        android:background="@color/meetmind_secondary" />

                    <!-- ── Storage Path ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_path_label"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/recordingPathText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/meetmind_secondary"
                            android:textIsSelectable="true"
                            android:textSize="11sp"
                            android:lineSpacingExtra="2dp"
                            tools:text="/storage/emulated/0/Android/data/com.office.meetmind/files/Music/Meeting_20260616_180000.m4a" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!--            AUDIO PLAYER CARD             -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/playerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/meetmind_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Section header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Audio Player"
                        android:textColor="@color/meetmind_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01" />

                    <!-- Waveform Placeholder -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="@color/meetmind_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <View android:layout_width="0dp" android:layout_height="14dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="18dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="68dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="22dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_secondary" />
                            <View android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1" android:layout_marginEnd="2dp" android:background="@color/meetmind_primary" />
                            <View android:layout_width="0dp" android:layout_height="16dp" android:layout_weight="1" android:background="@color/meetmind_secondary" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- SeekBar -->
                    <SeekBar
                        android:id="@+id/playbackSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:max="1000"
                        android:progress="0" />

                    <!-- Time Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/currentTimeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="12sp"
                            tools:text="00:00:00" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/totalTimeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/meetmind_secondary"
                            android:textSize="12sp"
                            tools:text="00:12:31" />
                    </LinearLayout>

                    <!-- ── Play · Pause ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/playButton"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="@string/play_audio"
                            app:icon="@drawable/ic_play"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/pauseButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:text="@string/pause_audio"
                            app:icon="@drawable/ic_pause"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />
                    </LinearLayout>

                    <!-- ── Resume · Stop ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/resumeButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:text="@string/resume_audio"
                            app:icon="@drawable/ic_play"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/stopButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:enabled="false"
                            android:text="@string/stop_audio"
                            app:icon="@drawable/ic_stop"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!--           AI ASSISTANT CARD              -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/meetmind_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Section header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI Assistant"
                        android:textColor="@color/meetmind_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Whisper Base · Offline transcription"
                        android:textColor="@color/meetmind_secondary"
                        android:textSize="13sp" />

                    <!-- Transcribe button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/transcribeButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/generate_transcript" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!--         DELETE RECORDING BUTTON          -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/delete_recording"
                android:textColor="?attr/colorError"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconTint="?attr/colorError"
                app:strokeColor="?attr/colorError" />

        </LinearLayout>

        <!-- ════════════════════════════════════════ -->
        <!--    LOADING OVERLAY — centered in frame   -->
        <!-- ════════════════════════════════════════ -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loadingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />

    </FrameLayout>
</androidx.core.widget.NestedScrollView>