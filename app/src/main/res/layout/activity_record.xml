<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/meetmind_background"
    tools:context=".RecordActivity">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/meetmind_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Recording Icon -->

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_record_background"/>

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <!-- Status -->

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="● Recording"
                android:textColor="#E53935"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Timer -->

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="monospace"
                android:text="00:00:00"
                android:textColor="@color/meetmind_primary"
                android:textSize="52sp"
                android:textStyle="bold"/>

            <!-- Subtitle -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Speak naturally. Audio is being recorded securely."
                android:textColor="@color/meetmind_secondary"
                android:textSize="15sp"/>

            <!-- Waveform Placeholder -->

            <ImageView
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:src="@android:drawable/ic_media_play"
                android:alpha=".25"/>

            <!-- Storage Info -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/stat_sys_download_done"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Automatically saved to device"
                    android:textColor="@color/meetmind_secondary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Stop Button -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="#E53935"
                android:text="Stop Recording"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_media_pause"
                app:iconGravity="textStart"
                app:iconPadding="10dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>